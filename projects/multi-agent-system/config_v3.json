      ],
      "skills": ["shell", "file_operations", "process_management", "environment_config", "deploy", "git", "github"],
      "capacity": 5,
      "current_load": 0,
      "status": "available",
      "sandbox": true,
      "permissions": {
        "code_write": false,
        "file_access": true,
        "command_exec": true,
        "network": false
