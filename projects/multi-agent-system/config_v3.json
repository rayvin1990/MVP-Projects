      "dangerous_commands_blocked": [
        "rm -rf",
        "rm -rf /",
        "dd if=/dev/zero",
        "mkfs",
        "chmod 777",
        "sudo rm",
        ":(){ :|:& };:"
      ],
      "responsible_steps": [9]
    }
  ],
  
  "workflow": {
    "name": "9 步极简执行流程（整合版）",
    "total_steps": 9,
    "current_step": 0,
    "status": "waiting",
    "steps": [
      {
        "step": 1,
        "name": "Reddit 挖痛点",
        "agent": "researcher",
        "criteria": ["高赞刚需", "垂直细分", "纯前端可做", "低维护"],
        "output": "pain_point_report"
      },
      {
        "step": 2,
        "name": "SEO 关键词提取",
        "agent": "researcher",
        "criteria": ["核心词", "长尾词", "标题描述"],
        "output": "keyword_list"
      },
      {
        "step": 3,
        "name": "产品极简设计",
        "agent": "product",
        "criteria": ["单核心功能", "原型", "内嵌 SEO"],
        "output": "prd_document"
      },
      {
        "step": 4,
        "name": "可行性强制校验",
        "agent": "commander_x",
        "criteria": ["纯前端", "无自建后端", "免费 API", "1 天可上线"],
        "output": "feasibility_report"
      },
      {
        "step": 5,
        "name": "指挥官分任务",
        "agent": "commander_x",
        "criteria": ["拆解任务", "明确 Agent 分工"],
        "output": "task_assignments"
      },
      {
        "step": 6,
        "name": "Engineer 生成代码",
        "agent": "engineer",
        "criteria": ["轻量纯前端", "可直接运行"],
        "output": "source_code"
      },
      {
        "step": 7,
        "name": "Tester 质检",
        "agent": "tester",
        "criteria": ["逻辑无误", "界面流畅", "无报错", "移动端适配"],
        "output": "test_report"
      },
      {
        "step": 8,
        "name": "尖叫度终审",
        "agent": "product",
        "criteria": ["3 秒懂", "一步操作", "有尖叫点"],
        "output": "scream_score",
        "co_auditor": "commander_x"
      },
      {
        "step": 9,
        "name": "部署上线",
        "agent": "executor",
        "criteria": ["阿里云打包 ZIP", "本地", "GitHub", "发布"],
        "output": "deployed_url"
      }
    ]
  },
  
  "security": {
    "sandbox_principle": true,
    "minimum_permission": true,
    "code_review_required": true,
    "resource_limit": {
      "timeout_seconds": 300,
      "max_memory_mb": 512,
      "max_cpu_percent": 50
    },
    "io_format_locked": true,
    "prompt_injection_protection": true,
    "history_cleanup": true,
    "dangerous_command_filter": true
  },
  
  "heartbeat": {
    "enabled": true,
    "pulse": {
      "frequency_interactions": 5,
      "timeout_seconds": 10,
      "format": "simple_status_code"
    },
    "deadlock_detection": {
      "enabled": true,
      "max_duplicate_responses": 3,
      "max_same_assignment": 3,
      "max_reasoning_tokens": 500,
      "actions": {
        "force_interrupt": true,
        "restart_thinking": true,
        "summarize_blocker": true
      }
    },
    "self_check": {
      "enabled": true,
      "interval_interactions": 5,
      "check_items": [
        "confidence_level",
        "task_progress",
        "agent_status",
        "error_count"
      ]
    },
    "resource_monitor": {
      "token_limit_warning_percent": 80,
      "memory_compression_enabled": true,
      "tool_call_frequency_limit": 5,
      "tool_call_window_seconds": 60,
      "actions": {
        "compress_memory": true,
        "pause_and_reflect": true
      }
    }
  },
  
  "settings": {
    "max_parallel_tasks": 3,
    "check_interval_minutes": 10,
    "auto_report": true,
    "report_time": "22:00",
    "silent_period": {
      "start": "23:00",
      "end": "08:00"
    },
    "step_timeout_hours": 4,
    "auto_retry": true,
    "max_retries": 2,
    "quality_gate": {
      "step_4_feasibility": ["frontend_only", "no_backend", "free_api", "one_day_launch"],
      "step_8_scream": ["3s_understand", "1s_operation", "has_scream_point"]
    }
  },
  
  "communication": {
    "protocol": "json",
    "format": {
      "from": "agent_id",
      "to": "agent_id",
      "type": "message_type",
      "step": "step_number",
      "payload": {}
    },
    "channels": {
      "task_assignment": "tasks/assignments",
      "status_update": "tasks/status",
      "completion": "tasks/completion",
      "errors": "tasks/errors",
      "audit": "system/audit"
    }
  },
  
  "compliance": {
    "zero_tolerance": true,
    "violation_actions": {
      "write_code": "immediate_stop_and_reassign",
      "run_command": "immediate_stop_and_reassign",
      "modify_file": "immediate_stop_and_reassign",
      "execute_task": "immediate_stop_and_reassign"
    },
    "audit_log": true,
    "heartbeat_check": true,
    "permission_review": true
  }
}
